{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server:dev": "tsx watch src/backend/server/index.ts",
    "db:generate": "drizzle-kit generate:mysql",
    "db:push": "drizzle-kit push:mysql",
    "build": "echo 'Railway: Usando archivos pre-construidos en local'",
    "build:local": "vite build --emptyOutDir && pnpm run build:server",
    "build:server": "npx esbuild src/backend/server/index.ts --bundle --platform=node --target=node22 --outfile=dist-server/index.js --format=esm --external:fsevents --external:mysql2 --packages=external",
    "start": "NODE_ENV=production node dist-server/index.js",
    "dev:server": "tsx watch src/backend/server/index.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.95.2",
    "@trpc/client": "^11.15.0",
    "@trpc/react-query": "^11.15.0",
    "@trpc/server": "^11.15.0",
    "@types/cors": "^2.8.19",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "express": "^4.22.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mysql2": "^3.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "vite": "^6.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.15",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
